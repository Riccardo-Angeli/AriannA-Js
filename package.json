{
  "name": "ariannajs",
  "version": "1.1.0",
  "description": "AriannA — Reactive UI framework. Performant like SolidJS, pleasant like React, native as the DOM.",
  "author": "Riccardo Angeli <riccardo.angeli@arianna.dev> (https://ariannajs.dev)",
  "license": "SEE LICENSE IN LICENSE",
  "type": "module",
  "main": "./core/index.ts",
  "module": "./core/index.ts",
  "types": "./core/index.ts",
  "bin": {
    "arianna": "./cli/arianna-cli.mjs"
  },
  "exports": {
    ".": {
      "types": "./core/index.ts",
      "import": "./core/index.ts",
      "default": "./core/index.ts"
    },
    "./core": {
      "types": "./core/Core.ts",
      "import": "./core/Core.ts"
    },
    "./observable": {
      "types": "./core/Observable.ts",
      "import": "./core/Observable.ts"
    },
    "./state": {
      "types": "./core/State.ts",
      "import": "./core/State.ts"
    },
    "./real": {
      "types": "./core/Real.ts",
      "import": "./core/Real.ts"
    },
    "./virtual": {
      "types": "./core/Virtual.ts",
      "import": "./core/Virtual.ts"
    },
    "./rule": {
      "types": "./core/Rule.ts",
      "import": "./core/Rule.ts"
    },
    "./stylesheet": {
      "types": "./core/Stylesheet.ts",
      "import": "./core/Stylesheet.ts"
    },
    "./directive": {
      "types": "./core/Directive.ts",
      "import": "./core/Directive.ts"
    },
    "./context": {
      "types": "./core/Context.ts",
      "import": "./core/Context.ts"
    },
    "./namespace": {
      "types": "./core/Namespace.ts",
      "import": "./core/Namespace.ts"
    },
    "./jsx-runtime": {
      "import": "./core/jsx/jsx-runtime.ts"
    },
    "./jsx-dev-runtime": {
      "import": "./core/jsx/jsx-dev-runtime.ts"
    },
    "./components": {
      "types": "./components/index.ts",
      "import": "./components/index.ts"
    },
    "./additionals": {
      "types": "./additionals/index.ts",
      "import": "./additionals/index.ts"
    },
    "./config": {
      "types": "./config/arianna.config.ts",
      "import": "./config/arianna.config.ts"
    }
  },
  "files": [
    "core/",
    "components/",
    "additionals/",
    "config/",
    "cli/",
    "types/",
    "README.md",
    "LICENSE",
    "LICENSES/",
    "CHANGELOG.md",
    "package.json",
    "tsconfig.json"
  ],
  "keywords": [
    "ui",
    "framework",
    "reactive",
    "real-dom",
    "virtual-dom",
    "signal",
    "fine-grained",
    "typescript",
    "no-vdom",
    "zero-deps",
    "web-components",
    "custom-elements",
    "dom",
    "state-management",
    "css-in-js",
    "tauri",
    "wasm",
    "svg",
    "mathml",
    "x3d",
    "observable",
    "pub-sub"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Riccardo-Angeli/AriannA-Js.git"
  },
  "homepage": "https://ariannajs.dev",
  "bugs": {
    "url": "https://github.com/Riccardo-Angeli/AriannA-Js/issues",
    "email": "bugs@arianna.dev"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "docs": "typedoc --out docs core/index.ts",
    "build": "node scripts/build.mjs",
    "build:min": "node scripts/build.mjs --minify",
    "bench": "node ./release/benchmarks/run.js",
    "prepublishOnly": "npm run typecheck"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "typedoc": "^0.25.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "sideEffects": [
    "./core/Namespace.ts"
  ],
  "funding": {
    "type": "commercial",
    "url": "https://ariannajs.dev/licensing"
  },
  "publishConfig": {
    "access": "public"
  }
}