# ── macOS ────────────────────────────────────────────────────────────────────
.DS_Store
**/.DS_Store
.AppleDouble
.LSOverride

# ── Windows ──────────────────────────────────────────────────────────────────
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ── Linux / Unix (editor backups) ────────────────────────────────────────────
*~
.directory
.Trash-*

# ── IDE / Editor ─────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
.project
.settings/
*.sublime-project
*.sublime-workspace

# ── Node / npm ───────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn-integrity
.pnp.*

# ── Build outputs ────────────────────────────────────────────────────────────
dist/
build/
out/
*.tsbuildinfo
.cache/
.parcel-cache/

# Compiled JS output (generated from .ts sources).
# Whitelist real .js sources (Vite configs, dist bundles) below.
additionals/*.js
components/*.js
components/**/*.js
core/*.js
config/*.js

# Keep these — they are real .js sources or final bundles
!release/dist/*.js
!release/benchmarks/**/*.js

# ── Environment / secrets ────────────────────────────────────────────────────
.env
.env.local
.env.*.local
*.pem
*.key

# ── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log

# ── Project-specific ─────────────────────────────────────────────────────────
PROJECT_STRUCTURE.txt
REPO_STRUCTURE.md