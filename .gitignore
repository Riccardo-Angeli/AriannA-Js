# ─────────────────────────────────────────────────────────────────────────────
# AriannA JS — .gitignore
# ─────────────────────────────────────────────────────────────────────────────
# Philosophy:
#   • Sources are .ts files only — every .js / .d.ts is generated.
#   • Builds (release/dist, release/types) are produced by `npm run build`.
#   • Personal / strategic docs stay local (e.g. 3D_ENTERPRISE_ROADMAP.md).
#   • Documentation under documentation/ IS committed.
# ─────────────────────────────────────────────────────────────────────────────


# ── OS noise ─────────────────────────────────────────────────────────────────
.DS_Store
**/.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*~
.directory
.Trash-*


# ── IDE / Editor ─────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
.project
.settings/
*.sublime-project
*.sublime-workspace


# ── Node / npm ───────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn-integrity
.pnp.*


# ── TypeScript build state ───────────────────────────────────────────────────
*.tsbuildinfo
tsconfig.tsbuildinfo
.cache/
.parcel-cache/


# ── Generated JS (transpiled from .ts) ───────────────────────────────────────
# Every .ts in sources produces a .js next to it during tsc compile.
# These are artefacts — not source.
additionals/*.js
components/*.js
components/**/*.js
core/*.js
core/**/*.js
config/*.js
cli/*.js
cli/**/*.js


# ── Generated .d.ts declarations ─────────────────────────────────────────────
# Produced by `tsc --declaration`. Real types come from the .ts sources.
types/
additionals/*.d.ts
components/**/*.d.ts
core/**/*.d.ts
config/*.d.ts


# ── Release artefacts ────────────────────────────────────────────────────────
# DECISION: commit pre-built bundles to release/dist/ so users can load via
# unpkg.com / jsdelivr without running the build. Everything else under
# release/ is ignored (types, intermediate builds, benchmarks output).
release/**
!release/dist/
!release/dist/*.js
!release/dist/*.js.map
!release/benchmarks/
!release/benchmarks/**/*.js


# ── Other build outputs ──────────────────────────────────────────────────────
dist/
build/
out/


# ── Tauri build artefacts (for example projects) ─────────────────────────────
target/
**/src-tauri/target/
**/src-tauri/gen/
**/src-tauri/Cargo.lock


# ── Environment / secrets ────────────────────────────────────────────────────
.env
.env.local
.env.*.local
*.pem
*.key


# ── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log


# ── Personal / strategic documents (kept local, not pushed) ──────────────────
# These contain business roadmaps, internal evaluations, or scratch notes that
# should not be public. Move them out of repo entirely when convenient.
3D_ENTERPRISE_ROADMAP.md
PROJECT_STRUCTURE.txt
REPO_STRUCTURE.md
documentation/internal/
documentation/private/
**/*.local.md
**/*.local.ts


# ── Devtools (development utilities, not part of distribution) ───────────────
# Comment out the next two lines if you DO want devtools committed.
devtools/
devtools/tests/


# ── Misc ─────────────────────────────────────────────────────────────────────
coverage/
.nyc_output/
*.tgz
/documentation/COMPONENT_CONVENTIONS.md
